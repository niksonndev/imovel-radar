# Copie para .env e preencha
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Intervalo em minutos entre verificações de alertas (padrão 30)
ALERT_CHECK_INTERVAL_MINUTES=30
# Intervalo em horas para watchlist (padrão 6)
WATCHLIST_CHECK_INTERVAL_HOURS=6
# Caminho do SQLite (padrão: ./data/bot.db)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# API key do ScrapingBee (https://www.scrapingbee.com)
SCRAPINGBEE_API_KEY=
