# Copie para .env e preencha
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Coleta agendada: horário local diário (padrão 05:00) no fuso IANA (padrão Maceió)
SCRAPE_CRON_HOUR=5
SCRAPE_CRON_MINUTE=0
SCRAPE_TIMEZONE=America/Maceio

